---
import type { JSX } from "astro/jsx-runtime";
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import { Icon } from "astro-icon/components";

import Layout from "@/layouts/Layout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return Promise.all(
    projects.map(async (project) => {
      const { Content } = await render(project);

      return {
        params: { slug: project.id },
        props: { ...project.data, Content },
      };
    }),
  );
}

interface Props {
  title: string;
  description: string;
  tags: string[];
  image?: {
    src: string;
    width: number;
    height: number;
    format: "png" | "jpg" | "jpeg" | "tiff" | "webp" | "gif" | "svg" | "avif";
  };
  link?: string;
  Content: () => JSX.Element;
}

const { title, description, tags, image, link, Content } = Astro.props;
---

<Layout>
  <div class="container mx-auto px-4 pt-24 pb-16">
    <div class="max-w-4xl mx-auto">
      <a
        href="/projects/"
        class="btn btn-ghost btn-sm gap-1 mb-8"
        data-astro-prefetch
      >
        <Icon name="tabler:arrow-left" /> Back to Projects
      </a>

      <div class="card bg-base-100 border border-base-200 mb-12">
        {
          image && (
            <figure class="h-64 w-full">
              <Image
                src={image}
                alt={title}
                class="w-full h-full object-cover"
              />
            </figure>
          )
        }

        <div class="card-body">
          <h1 class="card-title text-4xl mb-2">{title}</h1>
          <p class="text-base-content/80 mb-3">{description}</p>

          <div class="flex flex-wrap gap-2 mb-4">
            {
              tags.map((tag) => (
                <span class="badge badge-neutral badge-sm">{tag}</span>
              ))
            }
          </div>

          {
            link && (
              <div class="card-actions justify-end mt-2">
                <a
                  href={link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-primary"
                >
                  Visit Project
                </a>
              </div>
            )
          }
        </div>
      </div>

      <div class="prose prose-lg max-w-none">
        <Content />
      </div>
    </div>
  </div>
</Layout>
